

# Added by skill
OLLAMA_HOST=

# ── WeChat channel ──────────────────────────────────────────────────────────
# Set to true to enable the WeChat channel (scans QR code on first start)
ENABLE_WECHAT=false
# Optional: use PadLocal puppet for a more stable connection (requires paid token)
# WECHATY_PUPPET=wechaty-puppet-padlocal
# WECHATY_PUPPET_PADLOCAL_TOKEN=

# ── DingTalk channel ─────────────────────────────────────────────────────────
# Set to true to enable the DingTalk channel
ENABLE_DINGTALK=false
# AppKey and AppSecret from the DingTalk developer console (open.dingtalk.com)
# The robot must have Stream mode enabled (no public IP required)
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=

# ── Feishu/Lark channel ──────────────────────────────────────────────────────
# Set to true to enable the Feishu channel (uses WebSocket long-connection, no public IP needed)
ENABLE_FEISHU=true
# App ID and App Secret from Feishu developer console (open.feishu.cn)
# The app must have "Receive messages" and "Send messages" permissions
FEISHU_APP_ID=cli_a93a5ca83ab85bde
FEISHU_APP_SECRET=5n7lrt44vtuJgPNlq3UtnfDrWbKbbZv6

# ── Zenmux LLM provider ──────────────────────────────────────────────────────
# Zenmux API key — used for both Anthropic proxy and Gemini Vertex AI proxy
ZENMUX_API_KEY=sk-ai-v1-bfa32a2a84b82833c57e43e5c03d44c26ee9463e507787ba37917221cf7a7858

# Route Anthropic SDK calls through the Zenmux proxy
# (replaces direct Anthropic API access; supports claude-opus-4.6 and other models)
ANTHROPIC_API_KEY=sk-ai-v1-bfa32a2a84b82833c57e43e5c03d44c26ee9463e507787ba37917221cf7a7858
ANTHROPIC_BASE_URL=https://zenmux.ai/api/anthropic

# Override the default Claude model used by claude-code inside containers
CLAUDE_CODE_DEFAULT_MODEL=anthropic/claude-opus-4.6

# ── Proxy settings (for container access to host proxy) ───────────────────────
ASSISTANT_NAME=assistant
